# Copy this file to .env.local and fill in.
# Get these values from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Anthropic API key — enables AI features (Daily Edition, Weekly Retro,
# LLM quick-add parser, Smart Eisenhower). Optional: app degrades gracefully
# without it (chrono-node parsing, no editorial briefings).
# Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=
