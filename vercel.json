{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/reminders/dispatch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/keywords/reclassify",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/calendar-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/embeddings-sync",
      "schedule": "*/15 * * * *"
    }
  ]
}
